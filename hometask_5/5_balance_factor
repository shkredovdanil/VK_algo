#include <algorithm>

struct Node
{
    int data;
    Node *left;
    Node *right;
    int balance_factor;

    Node(int value) : data(value), left(nullptr), right(nullptr), balance_factor(0) {}
};

int
getHeight(Node *root)
{
    if (root == nullptr) {
        return 0;
    }

    int leftHeight = getHeight(root->left);
    int rightHeight = getHeight(root->right);

    return std::max(leftHeight, rightHeight) + 1;
}

/*
    Из двух высот поддеревьев берется максимальная и добавляется к единице
*/

void
computeBalanceFactors(Node *root)
{
    if (root == nullptr) {
        return;
    }

    int leftHeight = getHeight(root->left);
    int rightHeight = getHeight(root->right);

    root->balance_factor = leftHeight - rightHeight;

    computeBalanceFactors(root->left);
    computeBalanceFactors(root->right);
}
